{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Zoho Creator plugin-manifest.json",
  "type": "object",
  "required": ["name", "version", "config"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "config": {
      "type": "object",
      "required": ["widgets"],
      "properties": {
        "widgets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["location", "url"],
            "properties": {
              "location": {"type": "string", "minLength": 1},
              "url":      {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    "permissions": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
