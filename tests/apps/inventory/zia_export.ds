 application "Inventory Management System"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"

 	forms
	{
		form inventory_dashboard
		{
			displayname = "Inventory Dashboard"
			success message = "Inventory Dashboard Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			product
			(
				type = list	
				displayname = "Product"
				values  = products.ID
    			displayformat = [product_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			warehouse
			(
				type = list	
				displayname = "Warehouse"
				values  = warehouses.ID
    			displayformat = [warehouse_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			current_stock
			(
				type = number
				displayname = "Current Stock"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			reorder_status
			(
				type = picklist
				displayname = "Reorder Status"
				values = {"Out of Stock","Low Stock","In Stock"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			last_updated
			(
    			type = datetime
				displayname = "Last Updated"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Inventory Monitored","Reorder Triggered","Stock Verified","Purchase Order Created","Reorder Cancelled","Purchase Order Sent","Purchase Order Revised","Supplier Acknowledged","Purchase Order Follow-Up","Goods Received","Supplier Delayed","Supplier Follow-Up","Alternate Supplier Engaged","Quality Check In Progress","Goods Rejected","Quality Passed","Quality Failed","Inventory Updated","Return to Supplier","Partial Acceptance","Return Confirmed","Refund Processed","Replacement Shipped","Reorder Closed","Replacement Received"}
			}
		}
		form items
		{
			displayname = "Items"
			success message = "Item Added Successfully"
