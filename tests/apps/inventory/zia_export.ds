			)
			sat_unit_code
			(
    			type = text
				displayname = "SAT Unit Code"
	 			row = 1
	 			column = 1   
				width = medium
			)
			selling_price
			(
				type = decimal
				displayname = "Selling Price"
				maxchar = 16
	 			row = 1
	 			column = 1   
				width = medium
			)
			sku
			(
    			type = text
