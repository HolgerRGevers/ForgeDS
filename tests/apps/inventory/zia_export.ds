	reports
	{
		list stock_movements_Report
		{
			displayName = "All Stock Movements"
			show all rows from stock_movements    
			(
				product as "Product"
				warehouse as "Warehouse"
				movement_type as "Movement Type"
				quantity as "Quantity"
				movement_date as "Movement Date"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (movement_type == "Received")
				fields = [movement_type]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (movement_type == "Returned")
				fields = [movement_type]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (movement_type == "Shipped")
				fields = [movement_type]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban stock_movements_by_movement_type
		{
			displayName = "Movement Types"
			show all rows from stock_movements    
			(
				product as "Product"
				warehouse as "Warehouse"
				movement_type as "Movement Type"
				quantity as "Quantity"
				movement_date as "Movement Date"
			)
			options
			(
	 			display field = movement_type
	 		)
		}
		list inventory_dashboard_Report
		{
			displayName = "All Inventory Dashboards"
			show all rows from inventory_dashboard    
			(
				product as "Product"
				warehouse as "Warehouse"
				current_stock as "Current Stock"
				reorder_status as "Reorder Status"
				last_updated as "Last Updated"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (reorder_status == "In Stock")
				fields = [reorder_status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (reorder_status == "Low Stock")
				fields = [reorder_status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (reorder_status == "Out of Stock")
				fields = [reorder_status]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban inventory_dashboard_by_reorder_status
		{
			displayName = "Reorder Statuses"
			show all rows from inventory_dashboard    
			(
				product as "Product"
				warehouse as "Warehouse"
				current_stock as "Current Stock"
				reorder_status as "Reorder Status"
				last_updated as "Last Updated"
			)
			options
			(
	 			display field = reorder_status
	 		)
		}
		list products_Report
		{
			displayName = "All Products"
			show all rows from products    
			(
				product_id as "Product ID"
				product_name as "Product Name"
				sku as "SKU"
				category as "Category"
				unit_price as "Unit Price"
				(
					display = total,average,min,max	
				)
				quantity_on_hand as "Quantity On Hand"
				reorder_level as "Reorder Level"
				is_active as "Is Active"
				item as "Item"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (category == "Clothing")
				fields = [category]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (category == "Electronics")
				fields = [category]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (category == "Food")
				fields = [category]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
				"New Formatting4"
				{
				condition = (category == "Office")
				fields = [category]
				format = "color:#ffffff;background-color:#3598db;"
				}
			)
		}
		kanban products_by_category
		{
			displayName = "Categories"
			show all rows from products    
			(
				product_id as "Product ID"
				product_name as "Product Name"
				sku as "SKU"
				category as "Category"
				unit_price as "Unit Price"
				(
					display = total,average,min,max	
				)
				quantity_on_hand as "Quantity On Hand"
				reorder_level as "Reorder Level"
				is_active as "Is Active"
				item as "Item"
			)
			options
			(
	 			display field = category
	 		)
		}
		list warehouses_Report
		{
			displayName = "All Warehouses"
			show all rows from warehouses    
			(
				warehouse_id as "Warehouse ID"
				warehouse_name as "Warehouse Name"
				location as "Location"
				capacity as "Capacity"
			)
		}
		list items_Report
		{
			displayName = "All Items"
			show all rows from items    
			(
				brand as "Brand"
				cost_price as "Cost Price"
				created_time as "Created Time"
				dimension_unit as "Dimension Unit"
				ean as "EAN"
				height as "Height"
				hsn_or_sac_code as "HSN Or SAC Code"
				isbn as "ISBN"
				last_modified_time as "Last Modified Time"
				length_field as "Length"
				manufacturer as "Manufacturer"
				mpn as "MPN"
				name as "Name"
				opening_stock as "Opening Stock"
				opening_stock_rate_per_unit as "Opening Stock Rate Per Unit"
				purchase_account_name as "Purchase Account Name"
				purchase_description as "Purchase Description"
				reorder_point as "Reorder Point"
				sales_account_name as "Sales Account Name"
				sales_description as "Sales Description"
				sat_item_key_code as "SAT Item Key Code"
				sat_unit_code as "SAT Unit Code"
				selling_price as "Selling Price"
				sku as "SKU"
				upc as "UPC"
				weight as "Weight"
				weight_unit as "Weight Unit"
				width as "Width"
			)
		}
	}
	pages
	{
		page DashBoard
