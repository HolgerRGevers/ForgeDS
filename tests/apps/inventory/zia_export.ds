		form products
		{
			displayname = "Products"
			success message = "Product Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			product_id
			(
    			type = autonumber
				displayname = "Product ID"
				start index = 1
	 			row = 1
	 			column = 1   
				width = medium
			)
			product_name
			(
    			type = text
				displayname = "Product Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			sku
			(
    			type = text
				displayname = "SKU"
	 			row = 1
	 			column = 1   
				width = medium
			)
			category
			(
				type = picklist
				displayname = "Category"
				values = {"Office","Clothing","Electronics","Food","Other"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			unit_price
			(
				displayname = "Unit Price"
				type = USD
	 			row = 1
	 			column = 1   
				width = medium
			)
			quantity_on_hand
			(
				type = number
				displayname = "Quantity On Hand"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			reorder_level
			(
				type = number
				displayname = "Reorder Level"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			is_active
			(
    			type = checkbox
				displayname = "Is Active"
				initial value = false
	 			row = 1
	 			column = 1   
				width = medium
			)
			item
			(
				type = picklist	
				displayname = "Item"
				values  = items.ID
    			displayformat = [name]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
