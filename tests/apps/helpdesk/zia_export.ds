 application "Helpdesk Ticket Management"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"

 	forms
	{
		form comments
		{
			displayname = "Comments"
			success message = "Comment Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			ticket_1
			(
				type = list	
				displayname = "Ticket"
				values  = tickets.ID
    			displayformat = [ticket_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			comment
			(
    			type = textarea
				displayname = "Comment"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			author
			(
    			type = text
				displayname = "Author"
	 			row = 1
	 			column = 1   
				width = medium
			)
			comment_date
			(
    			type = datetime
				displayname = "Comment Date"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			is_internal
			(
    			type = checkbox
				displayname = "Is Internal"
				initial value = false
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form sla_configs
		{
			displayname = "SLA Configurations"
			success message = "Sla Configuration Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			priority
			(
    			type = text
				displayname = "Priority"
	 			row = 1
	 			column = 1   
				width = medium
			)
			resolution_hours
			(
				type = number
				displayname = "Resolution Hours"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			active
			(
    			type = checkbox
				displayname = "Active"
				initial value = false
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form tickets
		{
			displayname = "Tickets"
			success message = "Ticket Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			ticket_id
			(
    			type = autonumber
				displayname = "Ticket ID"
				start index = 1
	 			row = 1
	 			column = 1   
				width = medium
			)
			subject_1
			(
    			type = text
				displayname = "Subject"
	 			row = 1
	 			column = 1   
				width = medium
			)
			description
			(
    			type = textarea
				displayname = "Description"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			requester_email
			(
    			type = email
				displayname = "Requester Email"
	 			row = 1
	 			column = 1   
				width = medium
			)
			category
			(
				type = picklist
				displayname = "Category"
				values = {"Account","Bug","Question","Feature"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			priority
			(
				type = picklist
				displayname = "Priority"
				values = {"High","Urgent","Low","Medium"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			status
			(
				type = picklist
				displayname = "Status"
				values = {"New","Closed","In Progress","Resolved","Open","Waiting"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			assigned_to
			(
    			type = text
				displayname = "Assigned To"
	 			row = 1
	 			column = 1   
				width = medium
			)
			created_date
			(
    			type = datetime
				displayname = "Created Date"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			sla_config
			(
				type = list	
				displayname = "SLA Configuration"
				values  = sla_configs.ID
    			displayformat = [priority]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Ticket Created","Ticket Assigned","Ticket Escalated","Ticket In Progress","Ticket On Hold","Ticket Reassigned","Ticket Resolved","Ticket Requires More Information","Ticket Closed","Ticket Verified","Ticket Reopened"}
			}
		}
	}
	reports
	{
		list tickets_Report
		{
			displayName = "All Tickets"
			show all rows from tickets    
			(
				ticket_id as "Ticket ID"
				subject_1 as "Subject"
				description as "Description"
				requester_email as "Requester Email"
				category as "Category"
				priority as "Priority"
				status as "Status"
				assigned_to as "Assigned To"
				created_date as "Created Date"
				sla_config as "SLA Configuration"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (priority == "High")
				fields = [priority]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (priority == "Low")
				fields = [priority]
				format = "color:#000000;background-color:#1bbc9b;"
				}
			)
		}
		kanban tickets_by_status
		{
			displayName = "Statuses"
			show all rows from tickets    
			(
				ticket_id as "Ticket ID"
				subject_1 as "Subject"
				description as "Description"
				requester_email as "Requester Email"
				category as "Category"
				priority as "Priority"
				status as "Status"
				assigned_to as "Assigned To"
				created_date as "Created Date"
				sla_config as "SLA Configuration"
			)
			options
			(
	 			display field = status
	 		)
		}
		list comments_Report
		{
			displayName = "All Comments"
			show all rows from comments    
			(
				ticket_1 as "Ticket"
				comment as "Comment"
				author as "Author"
				comment_date as "Comment Date"
				is_internal as "Is Internal"
			)
		}
		list sla_configs_Report
		{
			displayName = "All Sla Configurations"
			show all rows from sla_configs    
			(
				priority as "Priority"
				resolution_hours as "Resolution Hours"
				active as "Active"
			)
		}
	}
	pages
	{
		page DashBoard
		{
			displayname = "Dashboard"
