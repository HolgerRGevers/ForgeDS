 application "Employee Leave Management"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"

 	forms
	{
		form department_summary
		{
			displayname = "Department Summary"
			success message = "Department Summary Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			department
			(
				type = picklist	
				displayname = "Department"
				values  = zoho_people_department.ID
    			displayformat = [department_name]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			total_requests
			(
				type = number
				displayname = "Total Requests"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			approved_requests
			(
				type = number
				displayname = "Approved Requests"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			rejected_requests
			(
				type = number
				displayname = "Rejected Requests"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			pending_requests
			(
				type = number
				displayname = "Pending Requests"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			avg_days_per_request
			(
				type = decimal
				displayname = "Avg Days Per Request"
				maxchar = 16
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
