				width = medium
			)
			leave_type
			(
				type = picklist
				displayname = "Leave Type"
				values = {"Annual","Personal","Sick"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			total
			(
				type = number
				displayname = "Total"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			used
			(
				type = number
