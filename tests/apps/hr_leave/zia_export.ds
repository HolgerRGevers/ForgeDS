	reports
	{
		list employees_Report
		{
			displayName = "All Employees"
			show all rows from employees    
			(
				emp_id as "Employee ID"
				first_name1 as "First Name"
				last_name1 as "Last Name"
				email as "Email"
				phone as "Phone"
				join_date as "Join Date"
				department as "Department"
			)
		}
		list leave_requests_Report
		{
			displayName = "All Requests"
			show all rows from leave_requests    
			(
				employee as "Employee"
				leave_type as "Leave Type"
				start_date as "Start Date"
				end_date as "End Date"
				days as "Days"
				status as "Status"
				reason as "Reason"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (leave_type == "Personal")
				fields = [leave_type]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (leave_type == "Sick")
				fields = [leave_type]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (leave_type == "Unpaid")
				fields = [leave_type]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban leave_requests_by_leave_type
		{
			displayName = "Leave Types"
			show all rows from leave_requests    
			(
				employee as "Employee"
				leave_type as "Leave Type"
				start_date as "Start Date"
				end_date as "End Date"
				days as "Days"
				status as "Status"
				reason as "Reason"
			)
			options
			(
	 			display field = leave_type
	 		)
		}
		list leave_balances_Report
		{
			displayName = "All Balances"
			show all rows from leave_balances    
			(
				employee as "Employee"
				leave_type as "Leave Type"
				total as "Total"
				used as "Used"
				remaining as "Remaining"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (leave_type == "Annual")
				fields = [leave_type]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (leave_type == "Personal")
				fields = [leave_type]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (leave_type == "Sick")
				fields = [leave_type]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban leave_balances_by_leave_type
		{
			displayName = "Leave Types"
			show all rows from leave_balances    
			(
				employee as "Employee"
				leave_type as "Leave Type"
				total as "Total"
				used as "Used"
				remaining as "Remaining"
			)
			options
			(
	 			display field = leave_type
	 		)
		}
		list department_summary_Report
		{
			displayName = "All Department Summaries"
			show all rows from department_summary    
			(
				department as "Department"
				total_requests as "Total Requests"
				approved_requests as "Approved Requests"
				rejected_requests as "Rejected Requests"
				pending_requests as "Pending Requests"
				avg_days_per_request as "Avg Days Per Request"
			)
		}
		list leave_trends_Report
		{
			displayName = "All Trends"
			show all rows from leave_trends    
			(
				leave_type as "Leave Type"
				month_1 as "Month"
				year_1 as "Year"
				total_days_requested as "Total Days Requested"
				total_requests as "Total Requests"
				approval_rate as "Approval Rate"
				(
					display = total,average,min,max	
				)
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (leave_type == "Annual")
				fields = [leave_type]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (leave_type == "Sick")
				fields = [leave_type]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (leave_type == "Unpaid")
				fields = [leave_type]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban leave_trends_by_leave_type
		{
			displayName = "Leave Types"
			show all rows from leave_trends    
			(
				leave_type as "Leave Type"
				month_1 as "Month"
				year_1 as "Year"
				total_days_requested as "Total Days Requested"
				total_requests as "Total Requests"
				approval_rate as "Approval Rate"
				(
					display = total,average,min,max	
				)
			)
			options
			(
	 			display field = leave_type
	 		)
		}
		list zoho_people_department_Report
		{
			displayName = "Zoho People Department Report"
