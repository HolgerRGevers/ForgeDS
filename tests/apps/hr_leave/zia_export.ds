				type = number
				displayname = "Remaining"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Leave Balance Created","Leave Balance Verified","Leave Balance Rejected","Leave Balance Approved","Leave Balance Updated","Leave Balance in Use","Leave Balance Reconciled","Leave Balance Suspended","Leave Balance Archived","Leave Balance Resumed"}
			}
		}
