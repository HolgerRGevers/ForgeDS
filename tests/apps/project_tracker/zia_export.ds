 application "Project Management Tracker"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"

 	forms
	{
		form project_progress
		{
			displayname = "Project Progress"
			success message = "Project Progress Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			project
			(
				type = list	
				displayname = "Project"
				values  = projects.ID
    			displayformat = [project_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			actual_completion
			(
    			type = percentage
				displayname = "Actual Completion"
				maxchar = 16
	 			row = 1
	 			column = 1   
				width = medium
			)
			last_updated
			(
    			type = datetime
				displayname = "Last Updated"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form projects
		{
			displayname = "Projects"
			success message = "Project Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			project_id
			(
    			type = autonumber
				displayname = "Project ID"
				start index = 1
	 			row = 1
	 			column = 1   
				width = medium
			)
			project_name
			(
    			type = text
				displayname = "Project Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			description
			(
    			type = textarea
				displayname = "Description"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			start_date
			(
    			type = date
				displayname = "Start Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			end_date
			(
    			type = date
				displayname = "End Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			status
			(
				type = picklist
				displayname = "Status"
				values = {"Active","On Hold","Completed","Planning","Cancelled"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			budget
			(
				displayname = "Budget"
				type = USD
	 			row = 1
	 			column = 1   
				width = medium
			)
			completion
			(
    			type = percentage
				displayname = "Completion"
				maxchar = 16
	 			row = 1
	 			column = 1   
				width = medium
			)
			owner
			(
    			type = text
				displayname = "Owner"
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Project Created","Project Planning","Project Cancelled","Project Approved","Project Rejected","Project In Progress","Project On Hold","Project Completed","Project Closed","Project Reopened"}
			}
		}
		form task_status_history
		{
			displayname = "Task Status History"
			success message = "Task Status History Added Successfully"
			Section
