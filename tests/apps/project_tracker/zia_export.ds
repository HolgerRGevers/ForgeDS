				type = picklist
				displayname = "Status"
				values = {"Todo","Done","In Review","In Progress"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			updated_at
			(
    			type = datetime
				displayname = "Updated At"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			changed_by
			(
    			type = text
				displayname = "Changed By"
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
