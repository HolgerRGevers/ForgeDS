	share_settings
	{
			"Read"
			{
				name = "Read"
				type = Users_Permissions
				permissions = {Chat:true, Predefined:true, ApiAccess:true, PIIAccess:true, ePHIAccess:true}
				description = "This profile will have read permission for all components\n"
			}
			"Write"
			{
				name = "Write"
				type = Users_Permissions
				permissions = {Chat:true, Predefined:true, ApiAccess:true, PIIAccess:true, ePHIAccess:true}
				description = "This profile will have write permission for all components\n"
			}
			"Team Lead"
			{
				name = "Team Lead"
				type = Users_Permissions
				permissions = {Chat:false, Predefined:false, ApiAccess:true, PIIAccess:true, ePHIAccess:true}
				description = "Supervise a group of team members and ensure task deadlines are met \n"
				ModulePermissions
				{
					project_progress
					{
						enabled= Viewall,Modifyall 
						allFieldsVisible= true 
						ReportPermissions
						{
							project_progress_Report={"View","Edit","Delete"}
						}
					}
					projects
					{
						enabled= Viewall,Modifyall 
						allFieldsVisible= true 
						ReportPermissions
						{
							projects_Report={"View","Edit","Delete"}
							projects_by_status={"View","Edit","Delete"}
						}
					}
					task_status_history
					{
						enabled= Viewall,Modifyall 
						allFieldsVisible= true 
						ReportPermissions
						{
							task_status_history_Report={"View","Edit","Delete"}
							task_status_history_by_status={"View","Edit","Delete"}
						}
					}
					time_entries
					{
						enabled= Viewall 
						allFieldsVisible= true 
						ReportPermissions
						{
							time_entries_Report={"View"}
						}
					}
					tasks
					{
						enabled= Viewall,Modifyall 
						allFieldsVisible= true 
						ReportPermissions
						{
							tasks_by_priority={"View","Edit","Delete"}
							tasks_Report={"View","Edit","Delete"}
						}
					}
				}
			}
			"Operations Analyst"
			{
				name = "Operations Analyst"
				type = Users_Permissions
