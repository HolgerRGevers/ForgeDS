	reports
	{
		list tasks_Report
		{
			displayName = "All Tasks"
			show all rows from tasks    
			(
				task_id as "Task ID"
				task_name as "Task Name"
				project as "Project"
				assignee as "Assignee"
				priority as "Priority"
				status as "Status"
				due_date as "Due Date"
				estimated_hours as "Estimated Hours"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (priority == "Critical")
				fields = [priority]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (priority == "High")
				fields = [priority]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (priority == "Medium")
				fields = [priority]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban tasks_by_priority
		{
			displayName = "Priorities"
			show all rows from tasks    
			(
				task_id as "Task ID"
				task_name as "Task Name"
				project as "Project"
				assignee as "Assignee"
				priority as "Priority"
				status as "Status"
				due_date as "Due Date"
				estimated_hours as "Estimated Hours"
			)
			options
			(
	 			display field = priority
	 		)
		}
		list project_progress_Report
		{
			displayName = "All Project Progress"
			show all rows from project_progress    
			(
				project as "Project"
				actual_completion as "Actual Completion"
				(
					display = total,average,min,max	
				)
				last_updated as "Last Updated"
			)
		}
		list time_entries_Report
		{
			displayName = "All Time Entries"
			show all rows from time_entries    
			(
				task as "Task"
				hours as "Hours"
				entry_date as "Entry Date"
				description as "Description"
			)
		}
		list projects_Report
		{
			displayName = "All Projects"
			show all rows from projects    
			(
				project_id as "Project ID"
				project_name as "Project Name"
				description as "Description"
				start_date as "Start Date"
				end_date as "End Date"
				status as "Status"
				budget as "Budget"
				(
					display = total,average,min,max	
				)
				completion as "Completion"
				(
					display = total,average,min,max	
				)
				owner as "Owner"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (status == "Active")
				fields = [status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (status == "On Hold")
				fields = [status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
			)
		}
		kanban projects_by_status
		{
			displayName = "Statuses"
			show all rows from projects    
			(
				project_id as "Project ID"
				project_name as "Project Name"
				description as "Description"
				start_date as "Start Date"
				end_date as "End Date"
				status as "Status"
				budget as "Budget"
				(
					display = total,average,min,max	
				)
				completion as "Completion"
				(
					display = total,average,min,max	
				)
				owner as "Owner"
			)
			options
			(
	 			display field = status
	 		)
		}
		list task_status_history_Report
		{
			displayName = "All Task Status Histories"
			show all rows from task_status_history    
			(
				task as "Task"
				status as "Status"
				updated_at as "Updated At"
				changed_by as "Changed By"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (status == "Done")
				fields = [status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (status == "In Review")
				fields = [status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (status == "Todo")
				fields = [status]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban task_status_history_by_status
		{
			displayName = "Statuses"
			show all rows from task_status_history    
			(
				task as "Task"
				status as "Status"
				updated_at as "Updated At"
				changed_by as "Changed By"
			)
			options
			(
	 			display field = status
	 		)
		}
	}
