		form sync_attempts
		{
			displayname = "Sync Attempts"
			success message = "Sync Attempt Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			incident
			(
				type = list	
				displayname = "Incident"
				values  = incident_reports.ID
    			displayformat = [incident_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			request_payload
			(
    			type = textarea
				displayname = "Request Payload"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			response_status
			(
    			type = text
				displayname = "Response Status"
	 			row = 1
	 			column = 1   
				width = medium
			)
			response_body
			(
    			type = textarea
				displayname = "Response Body"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			sync_timestamp
			(
    			type = datetime
				displayname = "Sync Timestamp"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			success
			(
    			type = checkbox
				displayname = "Success"
				initial value = false
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Sync Attempt Created","Sync In Progress","Sync Failed","Sync Successful","Sync Timed Out","Retry Sync","Sync Failed - Max Retries Reached","Sync Manual Intervention Required","Sync Completed","Sync Completed with Warnings","Sync Failed - Final"}
			}
		}
	}
	reports
	{
		list incident_reports_Report
		{
			displayName = "Incident Reports Report"
			show all rows from incident_reports    
			(
				incident_id as "Incident ID"
				category as "Category"
				description as "Description"
				status as "Status"
				reported_by as "Reported By"
				reported_date as "Reported Date"
				assigned_to as "Assigned To"
				location as "Location"
				priority as "Priority"
				source as "Source"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (category == "Environmental")
				fields = [category]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (category == "IT")
				fields = [category]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (category == "Security")
				fields = [category]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban incident_reports_by_category
		{
			displayName = "Categories"
			show all rows from incident_reports    
			(
				incident_id as "Incident ID"
				category as "Category"
				description as "Description"
				status as "Status"
				reported_by as "Reported By"
				reported_date as "Reported Date"
				assigned_to as "Assigned To"
				location as "Location"
				priority as "Priority"
				source as "Source"
			)
			options
			(
	 			display field = category
	 		)
		}
		list sync_attempts_Report
		{
			displayName = "All Sync Attempts"
			show all rows from sync_attempts    
			(
				incident as "Incident"
				request_payload as "Request Payload"
				response_status as "Response Status"
				response_body as "Response Body"
				sync_timestamp as "Sync Timestamp"
				success as "Success"
			)
		}
		list error_logs_Report
		{
			displayName = "Error Logs Report"
			show all rows from error_logs    
			(
				incident as "Incident"
				error_message as "Error Message"
				error_timestamp as "Error Timestamp"
				error_code as "Error Code"
				retry_count as "Retry Count"
				source_system as "Source System"
			)
		}
		list orders_Report
		{
			displayName = "All Orders"
			show all rows from orders    
			(
				credit_card_expiry as "Credit Card Expiry"
				credit_card_umber as "Credit Card umber"
				customer_address as "Customer Address"
				customer_city as "Customer City"
				customer_company as "Customer Company"
				customer_country as "Customer Country"
				customer_first_name as "Customer First Name"
				customer_last_name as "Customer Last Name"
				customer_phone as "Customer Phone"
				customer_postal_code as "Customer Postal Code"
				customer_state as "Customer State"
				date_added as "Date Added"
				date_updated as "Date Updated"
				discount_total as "Discount Total"
				email as "Email"
				folder_id as "Folder ID"
				fulfillment_id as "Fulfillment Id"
				fulfillment_name as "Fulfillment Name"
				handling_total as "Handling Total"
				order_total as "Order Total"
				payment_status as "Payment Status"
				payment_type as "Payment Type"
				processor_balance as "Processor Balance"
				processor_response as "Processor Response"
				product_total as "Product Total"
				quantity_total as "Quantity Total"
				refund_total as "Refund Total"
				shipping_address as "Shipping Address"
				shipping_city as "Shipping City"
				shipping_company as "Shipping Company"
				shipping_country as "Shipping Country"
				shipping_first_name as "Shipping First Name"
				shipping_last_name as "Shipping Last Name"
				shipping_method as "Shipping Method"
				shipping_phone as "Shipping Phone"
				shipping_postal_code as "Shipping Postal Code"
				shipping_state as "Shipping State"
				shipping_total as "Shipping Total"
				source_id as "Source ID"
				source_name as "Source Name"
				tax_total as "Tax Total"
				weight_total as "Weight Total"
			)
