 application "Incident Report Synchronization"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"

 	forms
	{
		form error_logs
		{
			displayname = "Error Logs"
			success message = "Data Added Successfully!"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			incident
			(
				type = list	
				displayname = "Incident"
				values  = incident_reports.ID
    			displayformat = [incident_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			error_message
			(
    			type = textarea
				displayname = "Error Message"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			error_timestamp
			(
    			type = datetime
				displayname = "Error Timestamp"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			error_code
			(
    			type = text
				displayname = "Error Code"
	 			row = 1
	 			column = 1   
				width = medium
			)
			retry_count
			(
				type = number
				displayname = "Retry Count"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			source_system
			(
    			type = text
				displayname = "Source System"
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form incident_reports
		{
			displayname = "Incident Reports"
			success message = "Data Added Successfully!"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			incident_id
			(
    			type = autonumber
				displayname = "Incident ID"
				start index = 1
	 			row = 1
	 			column = 1   
				width = medium
			)
			category
			(
				type = picklist
				displayname = "Category"
				values = {"Physical","Environmental","IT","Security","Other"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			description
			(
    			type = textarea
				displayname = "Description"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			status
			(
				type = picklist
				displayname = "Status"
				values = {"Submitted","Draft","Synced","Failed"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			reported_by
			(
    			type = text
				displayname = "Reported By"
	 			row = 1
	 			column = 1   
				width = medium
			)
			reported_date
			(
    			type = datetime
				displayname = "Reported Date"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			assigned_to
			(
    			type = text
				displayname = "Assigned To"
	 			row = 1
	 			column = 1   
				width = medium
			)
			location
			(
    			type = text
				displayname = "Location"
	 			row = 1
	 			column = 1   
				width = medium
			)
			priority
			(
				type = picklist
				displayname = "Priority"
				values = {"High","Low","Medium","Critical"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			source
			(
				type = picklist	
				displayname = "Source"
				values  = orders.ID
    			displayformat = [credit_card_expiry]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Incident Reported","Incident Assigned","Incident Escalated","Incident In Progress","Incident Reassigned","Incident On Hold","Incident Resolved","Incident Verified","Incident Reopened","Incident Closed"}
			}
		}
