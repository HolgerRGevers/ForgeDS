	reports
	{
		list overdue_invoices_Report
		{
			displayName = "All Overdue Invoices"
			show all rows from overdue_invoices    
			(
				invoice_id as "Invoice ID"
				customer as "Customer"
				due_date as "Due Date"
				days_overdue as "Days Overdue"
				status as "Status"
				escalation_date as "Escalation Date"
				last_notification_sent as "Last Notification Sent"
				notification_attempts as "Notification Attempts"
				triggered_by as "Triggered By"
			)
		}
		list escalation_logs_Report
		{
			displayName = "All Escalation Logs"
			show all rows from escalation_logs    
			(
				invoice as "Invoice"
				action_1 as "Action"
				action_date as "Action Date"
				user as "User"
				details as "Details"
				external_api_response as "External API Response"
			)
		}
		list notification_queue_Report
		{
			displayName = "All Notification Queues"
			show all rows from notification_queue    
			(
				invoice as "Invoice"
				notification_type as "Notification Type"
				url as "URL"
				method as "Method"
				payload as "Payload"
				status as "Status"
				attempt_count as "Attempt Count"
				last_attempt as "Last Attempt"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (status == "Failed")
				fields = [status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (status == "Pending")
				fields = [status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (status == "Sent")
				fields = [status]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban notification_queue_by_status
		{
			displayName = "Statuses"
			show all rows from notification_queue    
			(
				invoice as "Invoice"
				notification_type as "Notification Type"
				url as "URL"
				method as "Method"
				payload as "Payload"
				status as "Status"
				attempt_count as "Attempt Count"
				last_attempt as "Last Attempt"
			)
			options
			(
	 			display field = status
	 		)
		}
		list payments_received_Report
		{
			displayName = "Payments Received Report"
			show all rows from payments_received    
			(
				amount_applied as "Amount Applied"
				amount_received as "Amount Received"
				amount_refunded as "Amount Refunded"
				bank_charges as "Bank Charges"
				exchange_rate as "Exchange Rate"
				notes as "Notes"
				payment_date as "Payment Date"
				payment_form as "Payment Form"
