	 			column = 1   
				width = medium
			)
			action_date
			(
    			type = datetime
				displayname = "Action Date"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			user
			(
    			type = text
				displayname = "User"
	 			row = 1
	 			column = 1   
				width = medium
			)
			details
			(
    			type = textarea
				displayname = "Details"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			external_api_response
			(
    			type = textarea
				displayname = "External API Response"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
