 application "Invoice Overdue Management"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"

 	forms
	{
		form escalation_logs
		{
			displayname = "Escalation Logs"
			success message = "Escalation Log Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			invoice
			(
				type = picklist	
				displayname = "Invoice"
				values  = invoices.ID
    			displayformat = [adjustment]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			action_1
