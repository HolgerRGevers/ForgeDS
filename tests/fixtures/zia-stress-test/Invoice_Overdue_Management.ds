   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Invoice Created","Notification Sent","Escalation Pending","Notification Failed","Awaiting Response","Payment Received","Manual Intervention Required","Escalated to Supervisor","Escalation Sent","Escalation Failed","Invoice Closed","Legal Action Initiated"}
			}
		}
		form payments_received
		{
			displayname = "Payments Received"
			success message = "Data Added Successfully!"
