		form notification_queue
		{
			displayname = "Notification Queue"
			success message = "Notification Queue Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			invoice
			(
				type = picklist	
				displayname = "Invoice"
				values  = invoices.ID
    			displayformat = [adjustment]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			notification_type
			(
				type = radiobuttons
				displayname = "Notification Type"
				values = {"Escalation","Overdue"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			url
			(
    			type = url
				displayname = "URL"
	 			row = 1
	 			column = 1   
				width = medium
			)
			method
			(
				type = radiobuttons
				displayname = "Method"
				values = {"POST"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			payload
			(
    			type = textarea
				displayname = "Payload"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			status
			(
				type = picklist
				displayname = "Status"
				values = {"Failed","Pending","Sent"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			attempt_count
			(
				type = number
				displayname = "Attempt Count"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			last_attempt
			(
    			type = datetime
				displayname = "Last Attempt"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Notification Queued","Notification Sent","Notification Failed","Notification Retried","Notification Delivered","Notification Escalated","Notification Suppressed","Notification Acknowledged","Notification Closed"}
			}
		}
		form overdue_invoices
		{
			displayname = "Overdue Invoices"
			success message = "Overdue Invoice Added Successfully"
			Section
			(
