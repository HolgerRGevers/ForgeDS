// ============================================================
// Script:   expense_claims.success.Expense_Claim_Approval.extracted.dg
// Name:     Expense Claim Approval
// Location: expense_claims > on add > on success
// Trigger:  on add
// Purpose:  Extracted from .ds export
// Version:  v2.1 (extracted)
// ============================================================

glRec = gl_accounts[expense_category == input.category && Active == true];

if (glRec != null && glRec.count() > 0)
{
	glCode = glRec.gl_code;
	input.gl_code = glCode;
}
else
{
	// Fallback — flag for manual review
	input.gl_code = "MANUAL-REVIEW";
}

// Update status — inside {} (DG011 target)
input.status = "Approved";

// Audit trail — [] inside {} (DG006, DG007, DG009, DG012)
if (true)
{
	row = insert into approval_history
	[
		claim = input.ID
		action_1 = "Approved"
		actor = zoho.loginuser
		timestamp = zoho.currenttime
		comments = "Expense claim approved. GL Code: " + ifnull(input.gl_code, "pending")
		Added_User = zoho.loginuser
	];
}

// Sendmail notification — [] inside {} (DG010, DG015/DG016)
if (input.Email != null && input.Email != "")
{
	sendmail
	[
		from : zoho.adminuserid
		to : input.Email
		subject : "Expense Claim " + input.Claim_Reference + " Approved"
		message : "<h2>Claim Approved</h2><p>Your expense claim <b>" + input.Claim_Reference + "</b> for R " + input.amount_zar + " has been approved.</p><p>GL Code: " + ifnull(input.gl_code, "pending") + "</p><p>Approved by: " + zoho.loginuser + "</p>"
		content_type : Html
	];
}

