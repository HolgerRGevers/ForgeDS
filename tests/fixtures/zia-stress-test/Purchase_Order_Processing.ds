			(
    			type = text
				displayname = "Procurement Rule"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have productid
			(
    			type = text
				displayname = "Product ID"
	 			row = 1
	 			column = 1   
				width = medium
