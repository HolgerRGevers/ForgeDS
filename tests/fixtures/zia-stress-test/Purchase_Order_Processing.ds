			(
    			type = date
				displayname = "Validity Start Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			varblpurordunitisactive
			(
    			type = text
				displayname = "Variable Purchase Order Unit Active"
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form purchase_orders
		{
			displayname = "Purchase Orders"
			success message = "Purchase Order Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			order_id
			(
    			type = autonumber
				displayname = "Order ID"
				start index = 1
	 			row = 1
	 			column = 1   
				width = medium
			)
			vendor
			(
				type = picklist	
				displayname = "Vendor"
				values  = business_partner.ID
    			displayformat = [businesspartnerid]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			total_amount
			(
				displayname = "Total Amount"
				type = USD
	 			row = 1
	 			column = 1   
				width = medium
			)
			order_date
			(
    			type = date
				displayname = "Order Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			status
			(
				type = picklist
				displayname = "Status"
				values = {"Submitted","Draft","Approved","Rejected"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			submitted_by
			(
    			type = text
				displayname = "Submitted By"
	 			row = 1
	 			column = 1   
				width = medium
			)
			approval_status
			(
				type = picklist
				displayname = "Approval Status"
				values = {"Approved","Rejected","Pending"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			created_at
			(
    			type = datetime
				displayname = "Created At"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Purchase Order Created","Pending Approval","Draft","Approved","Rejected","Order Placed with Vendor","Order Confirmed by Vendor","Order Cancelled","Goods Received","Order On Hold","Goods Inspected","Invoice Received","Return Goods","Invoice Approved","Invoice Rejected","Payment Processed","Order Closed","Return Processed"}
			}
		}
	}
	reports
	{
		list line_items_Report
		{
			displayName = "All Line Items"
			show all rows from line_items    
			(
				purchase_order as "Purchase Order"
				product as "Product"
				quantity as "Quantity"
				unit_price as "Unit Price"
				(
					display = total,average,min,max	
				)
				line_total as "Line Total"
				(
					display = total,average,min,max	
				)
				description as "Description"
			)
		}
		list purchase_orders_Report
		{
			displayName = "All Purchase Orders"
			show all rows from purchase_orders    
			(
				order_id as "Order ID"
				vendor as "Vendor"
				total_amount as "Total Amount"
				(
					display = total,average,min,max	
				)
				order_date as "Order Date"
				status as "Status"
				submitted_by as "Submitted By"
				approval_status as "Approval Status"
				created_at as "Created At"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (status == "Draft")
				fields = [status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (status == "Submitted")
				fields = [status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
			)
		}
		kanban purchase_orders_by_status
		{
			displayName = "Statuses"
			show all rows from purchase_orders    
			(
				order_id as "Order ID"
				vendor as "Vendor"
				total_amount as "Total Amount"
				(
					display = total,average,min,max	
				)
				order_date as "Order Date"
				status as "Status"
				submitted_by as "Submitted By"
				approval_status as "Approval Status"
				created_at as "Created At"
			)
			options
			(
	 			display field = status
	 		)
		}
		list approval_history_Report
		{
			displayName = "All Approval Histories"
			show all rows from approval_history    
			(
				purchase_order as "Purchase Order"
				action_1 as "Action"
				performed_by as "Performed By"
				action_date as "Action Date"
				notes as "Notes"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (action_1 == "Approved")
				fields = [action_1]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (action_1 == "Rejected")
				fields = [action_1]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (action_1 == "Submitted")
				fields = [action_1]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban approval_history_by_action_1
		{
			displayName = "Actions"
			show all rows from approval_history    
			(
				purchase_order as "Purchase Order"
				action_1 as "Action"
				performed_by as "Performed By"
				action_date as "Action Date"
				notes as "Notes"
			)
			options
			(
	 			display field = action_1
	 		)
		}
		list order_notifications_Report
		{
			displayName = "All Order Notifications"
			show all rows from order_notifications    
			(
				purchase_order as "Purchase Order"
				sent_to as "Sent To"
				sent_at as "Sent At"
				subject_1 as "Subject"
				body as "Body"
				status as "Status"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (status == "Failed")
				fields = [status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (status == "Queued")
				fields = [status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (status == "Sent")
				fields = [status]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban order_notifications_by_status
		{
			displayName = "Statuses"
			show all rows from order_notifications    
			(
				purchase_order as "Purchase Order"
				sent_to as "Sent To"
				sent_at as "Sent At"
				subject_1 as "Subject"
				body as "Body"
				status as "Status"
			)
			options
			(
	 			display field = status
	 		)
		}
