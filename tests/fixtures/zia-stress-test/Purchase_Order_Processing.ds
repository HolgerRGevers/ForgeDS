 application "Purchase Order Processing"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"

 	forms
	{
		form approval_history
		{
			displayname = "Approval History"
			success message = "Approval History Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			purchase_order
			(
				type = list	
				displayname = "Purchase Order"
				values  = purchase_orders.ID
    			displayformat = [order_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			action_1
			(
				type = picklist
				displayname = "Action"
				values = {"Submitted","Approved","Rejected"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			performed_by
			(
    			type = text
				displayname = "Performed By"
	 			row = 1
	 			column = 1   
				width = medium
			)
			action_date
			(
    			type = datetime
				displayname = "Action Date"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			notes
			(
    			type = textarea
				displayname = "Notes"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
