 application "Expense Claim Approval"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"

 	forms
	{
		form approval_thresholds
		{
			displayname = "Approval Thresholds"
			success message = "Approval Threshold Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			tier_name
			(
    			type = text
				displayname = "Tier Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			max_amount_zar
			(
				displayname = "Max Amount ZAR"
				type = USD
	 			row = 1
	 			column = 1   
				width = medium
			)
			active
			(
    			type = checkbox
				displayname = "Active"
				initial value = false
	 			row = 1
	 			column = 1   
				width = medium
			)
			created_time
			(
    			type = datetime
				displayname = "Created Time"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			last_modified_time
			(
    			type = datetime
				displayname = "Last Modified Time"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Tier Created","Tier Active","Tier Inactive","Tier Updated","Tier Deleted"}
			}
		}
		form expense_claims
		{
			displayname = "Expense Claims"
			success message = "Expense Claim Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			employee
			(
				type = picklist	
				displayname = "Employee"
				values  = users.ID
    			displayformat = [email_address]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			expense_date
			(
    			type = date
				displayname = "Expense Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			total_amount
			(
				displayname = "Total Amount"
				type = USD
	 			row = 1
	 			column = 1   
				width = medium
			)
			status
			(
				type = picklist
				displayname = "Status"
				values = {"Draft","Approved","Rejected","Pending"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			priority
			(
				type = radiobuttons
				displayname = "Priority"
				values = {"Urgent","Normal"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			project
			(
				type = picklist	
				displayname = "Project"
				values  = projects.ID
    			displayformat = [project_name]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			expense_type
			(
    			type = text
				displayname = "Expense Type"
	 			row = 1
	 			column = 1   
				width = medium
			)
			description
			(
    			type = textarea
				displayname = "Description"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			approval_threshold
			(
				type = list	
				displayname = "Approval Threshold"
				values  = approval_thresholds.ID
    			displayformat = [tier_name]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Expense Claim Created","Pending Approval","Draft Saved","Under Review","Rejected","Pending Additional Information","Approved","Escalated for Review","Payment Processed","Payment Sent","Payment Failed","Closed"}
			}
		}
