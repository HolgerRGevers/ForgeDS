	reports
	{
		list expense_claims_Report
		{
			displayName = "All Expense Claims"
			show all rows from expense_claims    
			(
				employee as "Employee"
				expense_date as "Expense Date"
				total_amount as "Total Amount"
				(
					display = total,average,min,max	
				)
				status as "Status"
				priority as "Priority"
				project as "Project"
				expense_type as "Expense Type"
				description as "Description"
				approval_threshold as "Approval Threshold"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (status == "Approved")
				fields = [status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (status == "Draft")
				fields = [status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (status == "Rejected")
				fields = [status]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban expense_claims_by_status
		{
			displayName = "Statuses"
			show all rows from expense_claims    
			(
				employee as "Employee"
				expense_date as "Expense Date"
				total_amount as "Total Amount"
				(
					display = total,average,min,max	
				)
				status as "Status"
				priority as "Priority"
				project as "Project"
				expense_type as "Expense Type"
				description as "Description"
				approval_threshold as "Approval Threshold"
			)
			options
			(
	 			display field = status
	 		)
		}
