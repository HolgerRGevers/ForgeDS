	reports
	{
		list approval_history_Report
		{
			displayName = "approval_history_Report"
			show all rows from approval_history    
			(
				purchase_order as "purchase_order"
				action_1 as "action_1"
				performed_by as "performed_by"
				action_date as "action_date"
				notes as "notes"
			)
		}
		list approval_thresholds_Report
		{
			displayName = "approval_thresholds_Report"
			show all rows from approval_thresholds    
			(
				tier_name as "tier_name"
				max_amount_zar as "max_amount_zar"
				active as "active"
				created_time as "created_time"
				last_modified_time as "last_modified_time"
			)
		}
		list business_partner_Report
		{
			displayName = "business_partner_Report"
			show all rows from business_partner    
			(
				academictitle as "academictitle"
				additionallastname as "additionallastname"
				authorizationgroup as "authorizationgroup"
				birthdate as "birthdate"
				businesspartnerbirthdatestatus as "businesspartnerbirthdatestatus"
			)
		}
		list error_logs_Report
		{
			displayName = "error_logs_Report"
