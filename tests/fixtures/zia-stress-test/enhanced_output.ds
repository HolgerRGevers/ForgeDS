		workflow
		{
		form
		{
			Purchase_Order_On_Add as "Purchase Order On Add"
			{
				type =  form
				form = purchase_orders

				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
							if (input.Total == null || input.Total <= 0)
							{
								cancel submit;
								alert "Total must be greater than zero";
							}

							// Look up vendor with null guard (DG005 target)
							vendor = Vendors[Vendor_ID == input.Vendor_ID];
							if (vendor != null)
							{
								// Subform row insertion — nested parens stress parser
								lineRow = Purchase_Orders.Line_Items();
								lineRow.Item_Name = input.Item_Description;
								lineRow.Amount = input.Total;
								lineRow.Vendor_Name = ifnull(vendor.Vendor_Name, "Unknown");
								input.Line_Items.insert(lineRow);

								// Audit trail insert — [] inside {} (DG006, DG007, DG009, DG012)
								row = insert into Approval_History
								[
									claim = input.ID
									action_1 = "Submitted"
									actor = zoho.loginuser
									timestamp = zoho.currenttime
									comments = "Purchase Order submitted for " + ifnull(vendor.Vendor_Name, "unknown vendor")
									Added_User = zoho.loginuser
								];

								// HTML sendmail — [] inside {} (DG010, DG015/DG016)
								sendmail
								[
									from : zoho.adminuserid
									to : input.Requester_Email
									subject : "Purchase Order " + input.PO_Number + " Submitted"
									message : "<h2>Purchase Order Submitted</h2><table border=\"1\"><tr><td>PO Number</td><td>" + input.PO_Number + "</td></tr><tr><td>Vendor</td><td>" + ifnull(vendor.Vendor_Name, "N/A") + "</td></tr><tr><td>Total</td><td>R " + input.Total + "</td></tr></table><p>This order is now pending approval.</p>"
									content_type : Html
								];
							}
							else
							{
								cancel submit;
								alert "Vendor not found. Please select a valid vendor.";
							}
						)
					}
				}

			}
			Expense_Claim_Validate as "Expense Claim Validate"
			{
				type =  form
				form = expense_claims

				record event = on edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
							if (thisapp.permissions.isUserInRole("Finance Manager"))
							{
								// Threshold lookup with null guard (DG005 target)
								thresholdRec = approval_thresholds[tier_name == "Tier 1" && Active == true];

								if (thresholdRec != null)
								{
									// ifnull with 999.99 fallback — DG014 validates this value
									thresholdAmount = ifnull(thresholdRec.max_amount_zar, 999.99);
								}
								else
								{
									thresholdAmount = 999.99;
								}

								// DELIBERATE DG013 TRAP: mixed && and || without full parentheses
								// Creator evaluates || before && — this is ambiguous
								// Linter should flag: "Mixed && and || — add parentheses"
								if ((input.amount_zar > thresholdAmount && input.status == "Pending") || input.Requires_Dual_Approval == true)
								{
									cancel submit;
									alert "This claim exceeds your approval threshold. Requires dual approval.";
								}

								// Correct version would be:
								// if ((input.amount_zar > thresholdAmount && input.status == "Pending") || input.Requires_Dual_Approval == true)

								// Status update — inside {} (DG011 target)
								if (input.amount_zar <= thresholdAmount)
								{
									input.status = "Pending Line Manager";
								}
							}
						)
					}
				}

			}
			Expense_Claim_Approval as "Expense Claim Approval"
			{
				type =  form
				form = expense_claims

				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
							glRec = gl_accounts[expense_category == input.category && Active == true];

							if (glRec != null && glRec.count() > 0)
							{
								glCode = glRec.gl_code;
								input.gl_code = glCode;
							}
							else
							{
								// Fallback — flag for manual review
								input.gl_code = "MANUAL-REVIEW";
							}

							// Update status — inside {} (DG011 target)
							input.status = "Approved";

							// Audit trail — [] inside {} (DG006, DG007, DG009, DG012)
							if (true)
							{
								row = insert into approval_history
								[
									claim = input.ID
									action_1 = "Approved"
									actor = zoho.loginuser
									timestamp = zoho.currenttime
									comments = "Expense claim approved. GL Code: " + ifnull(input.gl_code, "pending")
									Added_User = zoho.loginuser
								];
							}

							// Sendmail notification — [] inside {} (DG010, DG015/DG016)
							if (input.Email != null && input.Email != "")
							{
								sendmail
								[
									from : zoho.adminuserid
									to : input.Email
									subject : "Expense Claim " + input.Claim_Reference + " Approved"
									message : "<h2>Claim Approved</h2><p>Your expense claim <b>" + input.Claim_Reference + "</b> for R " + input.amount_zar + " has been approved.</p><p>GL Code: " + ifnull(input.gl_code, "pending") + "</p><p>Approved by: " + zoho.loginuser + "</p>"
									content_type : Html
								];
							}

							// ---- ON REJECT (companion handler) ----
							// Note: In .ds export, this appears as a separate on reject block
							// with its own on load ( ... ) script container.
							//
							// On reject handler would contain:
							//   input.status = "Rejected";
							//   insert into approval_history [
							//       claim = input.ID
							//       action_1 = "Rejected"
							//       actor = zoho.loginuser
							//       timestamp = zoho.currenttime
							//       comments = input.Rejection_Reason
							//       Added_User = zoho.loginuser
							//   ];
							//   sendmail [ from : zoho.adminuserid to : input.Email
							//       subject : "Claim Rejected" message : rejection HTML ];
						)
					}
				}

			}
			Incident_Sync_Workflow as "Incident Sync Workflow"
			{
				type =  form
				form = incident_reports

				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
							try
							{
								// Build request parameters using Map
								params = Map();
								params.put("id", input.ID);
								params.put("type", ifnull(input.Category, "General"));
								params.put("priority", ifnull(input.Priority, "Medium"));
								params.put("reporter", zoho.loginuser);

								// Build headers map
								headers = Map();
								headers.put("Content-Type", "application/json");
								headers.put("X-Source", "ZohoCreator");

								// invokeUrl — [] inside try {} (DG010 target)
								resp = invokeUrl
								[
									url : "https://api.example.com/incidents"
									type : POST
									parameters : params.toString()
									headers : headers
								];

								// Parse response — nested parens stress parser
								if (resp != null)
								{
									resultMap = resp.toMap();
									externalId = resultMap.get("id");
									syncStatus = resultMap.get("status");

									if (syncStatus == "ok")
									{
										// Status update — inside nested {} (DG011 target)
										input.status = "Synced";
										input.External_ID = externalId;

										// Audit trail — [] inside nested {} (DG006, DG009)
										row = insert into Audit_Log
										[
											action = "Synced"
											record_id = input.ID
											details = "Synced to external system. ID: " + ifnull(externalId, "unknown")
											timestamp = zoho.currenttime
											Added_User = zoho.loginuser
										];
									}
									else
									{
										// Partial failure — log but don't block
										input.status = "Sync Failed";

										row = insert into Error_Log
										[
											message = "Sync returned non-ok status: " + ifnull(syncStatus, "null")
											record_id = input.ID
											timestamp = zoho.currenttime
											Added_User = zoho.loginuser
										];
									}
								}
							}
							catch (e)
							{
								// Error logging — [] inside catch {} (second insert target in same script)
								input.status = "Sync Error";

								row = insert into Error_Log
								[
									message = e
									record_id = input.ID
									timestamp = zoho.currenttime
									Added_User = zoho.loginuser
								];
							}
						)
					}
				}

			}
		}

		schedule
		{
			Daily_Overdue_Checker as "Daily Overdue Checker"
			{
				type =  schedule
				form = invoices
				time zone = "Africa/Johannesburg"
				on start
				{
					actions 
					{
					on load
					(
						records = Invoices[Status == "Pending" && Due_Date < zoho.currentdate];

						if (records != null && records.count() > 0)
						{
							for each rec in records
							{
								days = daysBetween(rec.Due_Date, zoho.currentdate);

								if (days > 30)
								{
									// Update status — inside {} control flow
									rec.Status = "Escalated";

									// invokeUrl with POST — [] inside {} (DG010 target)
									params = Map();
									params.put("invoice_id", rec.ID);
									params.put("days_overdue", days);
									params.put("vendor", ifnull(rec.Vendor_Name, "Unknown"));

									resp = invokeUrl
									[
										url : "https://api.example.com/notify"
										type : POST
										parameters : params.toString()
										headers : {"Content-Type": "application/json"}
									];

									// Audit trail — [] inside {} (DG006, DG009)
									row = insert into Audit_Log
									[
										action = "Overdue Escalation"
										record_id = rec.ID
										details = "Invoice overdue by " + days + " days"
										timestamp = zoho.currenttime
										Added_User = zoho.adminuser
									];
								}
							}
						}
					)
					}
				}
			}
		}



	}
