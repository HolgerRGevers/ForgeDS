# forgeds.yaml — project-level configuration for ForgeDS engine
# Copy this file to your Zoho Creator project root as "forgeds.yaml"

project:
  name: "My Zoho Creator App"
  version: "0.1.0"

# Deluge linter settings
lint:
  threshold_fallback: "999.99"
  dual_threshold_fallback: "5000.00"
  demo_email_domains:
    - "yourdomain.com"
    - "example.com"
    - "placeholder.com"

# Cross-environment mapping (hybrid linter + validator + uploader)
schema:
  mandatory_zoho_fields:
    - ["form_name", "field_name"]

  table_to_form:
    AccessTableName: "zoho_form_name"

  fk_relationships:
    - child: ["ChildTable", "FK_Column"]
      parent: ["ParentTable", "PK_Column"]

  upload_order:
    - ["ParentTable", "parent_form"]
    - ["ChildTable", "child_form"]

  exclude_fields: ["ID", "Added_User"]

# Seed data paths (relative to project root)
seed_data_dir: "config/seed-data"

# Knowledge base — documentation scraper & graph
knowledge:
  raw_md_dir: "raw_md"
  knowledge_dir: "knowledge"
  scrape_delay: 2
  follow_links: true        # crawl index pages for leaf doc links
  parallel: true             # scrape modules in parallel threads
  max_depth: 2               # max crawl depth from seed URLs

  sources:
    # --- Tier 1: Critical (language core + Catalyst CLI) ---
    - url: "https://docs.catalyst.zoho.com/en/cli/v1/data-store-import-and-export/import-operation/"
      module: catalyst-cli
    - url: "https://docs.catalyst.zoho.com/en/cli/v1/data-store-import-and-export/export-operation/"
      module: catalyst-cli

    - url: "https://www.zoho.com/deluge/help/functions/text.html"
      module: deluge-functions
      follow_links: true
    - url: "https://www.zoho.com/deluge/help/functions/number.html"
      module: deluge-functions
      follow_links: true
    - url: "https://www.zoho.com/deluge/help/functions/date-time.html"
      module: deluge-functions
      follow_links: true
    - url: "https://www.zoho.com/deluge/help/functions/time.html"
      module: deluge-functions
      follow_links: true
    - url: "https://www.zoho.com/deluge/help/functions/collection.html"
      module: deluge-functions
      follow_links: true
    - url: "https://www.zoho.com/deluge/help/functions/list.html"
      module: deluge-functions
      follow_links: true
    - url: "https://www.zoho.com/deluge/help/functions/key-value.html"
      module: deluge-functions
      follow_links: true
    - url: "https://www.zoho.com/deluge/help/functions/logical.html"
      module: deluge-functions
      follow_links: true
    - url: "https://www.zoho.com/deluge/help/functions/type-check.html"
      module: deluge-functions
      follow_links: true
    - url: "https://www.zoho.com/deluge/help/functions/conversion.html"
      module: deluge-functions
      follow_links: true
    - url: "https://www.zoho.com/deluge/help/functions/xml.html"
      module: deluge-functions
      follow_links: true
    - url: "https://www.zoho.com/deluge/help/functions/utilities.html"
      module: deluge-functions
      follow_links: true
    - url: "https://www.zoho.com/deluge/help/file-methods.html"
      module: deluge-functions
      follow_links: true

    - url: "https://www.zoho.com/deluge/help/data-access.html"
      module: deluge-data-access
      follow_links: true

    - url: "https://www.zoho.com/deluge/help/variables.html"
      module: deluge-core
    - url: "https://www.zoho.com/deluge/help/system-variables.html"
      module: deluge-core
    - url: "https://www.zoho.com/deluge/help/datatypes.html"
      module: deluge-core
      follow_links: true
    - url: "https://www.zoho.com/deluge/help/operators.html"
      module: deluge-core
      follow_links: true
    - url: "https://www.zoho.com/deluge/help/conditions.html"
      module: deluge-core
      follow_links: true

    - url: "https://www.zoho.com/deluge/help/encryption-tasks.html"
      module: deluge-encryption
      follow_links: true

    # --- Tier 2: Integrations ---
    - url: "https://www.zoho.com/deluge/help/crm-tasks.html"
      module: deluge-integrations
      follow_links: true
    - url: "https://www.zoho.com/deluge/help/creator-tasks.html"
